# ─────────────────────────────────────────────────────────────────────────────
# UNCLINQ BACKEND — Environment Variables
# Copy to .env for local development. Never commit .env to git.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173

# ── Database (PostgreSQL) ─────────────────────────────────────────────────────
# Local: matches docker-compose.yml
# Production: Railway/Render sets this automatically
DATABASE_URL=postgresql://postgres:postgres123@localhost:5433/unclinq

# ── Redis ─────────────────────────────────────────────────────────────────────
# Local: matches docker-compose.yml (optional — app works without it)
# Production: Railway/Render sets this automatically
REDIS_URL=redis://localhost:6379

# ── JWT & Security ────────────────────────────────────────────────────────────
# Generate a strong secret: openssl rand -base64 48
# NEVER use the dev secret in production
JWT_SECRET=dev-only-secret-change-in-production-min-32-chars

# ── AI: Anthropic (Claude) ────────────────────────────────────────────────────
# Required for: Emora AI chat, Pattern Reports, onboarding style assessment
# Get key at: https://console.anthropic.com
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6

# ── AI: Google Gemini ─────────────────────────────────────────────────────────
# Required for: Action Lab matching, Insight Tab personalisation
# Get key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
# Used for: OTP login codes, password reset emails
# Leave ALL blank in local dev — auto-uses Ethereal test inbox (preview in console)
#
# Production options (choose one):
#   Resend   -> SMTP_HOST=smtp.resend.com  | PORT=465 | USER=resend  | PASS=re_...
#   SendGrid -> SMTP_HOST=smtp.sendgrid.net| PORT=587 | USER=apikey  | PASS=SG...
#   Gmail    -> SMTP_HOST=smtp.gmail.com   | PORT=587 | USER=you@gmail.com | PASS=app-password
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@unclinq.app
