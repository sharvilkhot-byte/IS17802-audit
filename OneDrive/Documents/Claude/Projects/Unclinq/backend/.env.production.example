# ─── Unclinq — Production Environment Variables ────────────────────────────
# Set these in Railway (backend service → Variables tab)

# Server
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://your-app.vercel.app

# Database — Railway sets this automatically when you add a PostgreSQL plugin
DATABASE_URL=postgresql://...

# Redis — Railway sets this automatically when you add a Redis plugin
REDIS_URL=redis://...

# JWT — generate: openssl rand -base64 48
JWT_SECRET=your-very-long-random-secret-min-32-chars

# AI APIs
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-sonnet-4-6
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Email SMTP — Resend (recommended free tier)
SMTP_HOST=smtp.resend.com
SMTP_PORT=465
SMTP_USER=resend
SMTP_PASSWORD=re_your_api_key
SMTP_FROM=noreply@unclinq.app
